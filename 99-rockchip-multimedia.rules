# MPP/VPU/RGA 权限规则
SUBSYSTEM=="video4linux", GROUP="video", MODE="0660"
KERNEL=="mpp_service", GROUP="video", MODE="0660"
KERNEL=="rkvdec", GROUP="video", MODE="0660"
KERNEL=="rkvenc", GROUP="video", MODE="0660"
KERNEL=="rga", GROUP="video", MODE="0660"
KERNEL=="vepu", GROUP="video", MODE="0660"
KERNEL=="avsd", GROUP="video", MODE="0660"
KERNEL=="h265e", GROUP="video", MODE="0660"
# DMA Heap 权限（MPP 编码器需要）
KERNEL=="reserved", SUBSYSTEM=="dma_heap", GROUP="video", MODE="0660"
KERNEL=="system", SUBSYSTEM=="dma_heap", GROUP="video", MODE="0660"
KERNEL=="system-uncached", SUBSYSTEM=="dma_heap", GROUP="video", MODE="0660"
