From 82fffbc14066be83d569fd2c3dacead4b2bba4cd Mon Sep 17 00:00:00 2001
From: Jeffy Chen <jeffy.chen@rock-chips.com>
Date: Tue, 11 Apr 2023 12:02:50 +0800
Subject: [PATCH 15/45] waylandsink: Fix crash when setting fullscreen property

Tested on RK3588 EVB with:
gst-launch-1.0 videotestsrc ! waylandsink fullscreen=1

Signed-off-by: Jeffy Chen <jeffy.chen@rock-chips.com>
---
 gst-libs/gst/wayland/gstwlwindow.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/gst-libs/gst/wayland/gstwlwindow.c b/gst-libs/gst/wayland/gstwlwindow.c
index 6cf0f17..8e098db 100644
--- a/gst-libs/gst/wayland/gstwlwindow.c
+++ b/gst-libs/gst/wayland/gstwlwindow.c
@@ -280,7 +280,8 @@ gst_wl_window_ensure_fullscreen (GstWlWindow * self, gboolean fullscreen)
 {
   GstWlWindowPrivate *priv;
 
-  g_return_if_fail (self);
+  if (!self)
+    return;
 
   priv = gst_wl_window_get_instance_private (self);
   if (fullscreen)
