From 64976f9c782ddd836e20a61c1337a115c73c0660 Mon Sep 17 00:00:00 2001
From: Build <build@local>
Date: Sun, 1 Mar 2026 13:50:24 +0800
Subject: [PATCH 06/45] waylandsink: Enable changing window handle


diff --git a/ext/wayland/gstwaylandsink.c b/ext/wayland/gstwaylandsink.c
index 52f5e61..9de65dc 100644
--- a/ext/wayland/gstwaylandsink.c
+++ b/ext/wayland/gstwaylandsink.c
@@ -798,9 +798,10 @@ render_last_buffer (GstWaylandSink * self, gboolean redraw)
 
   wlbuffer = gst_buffer_get_wl_buffer (self->display, self->last_buffer);
 
-  if (G_UNLIKELY (self->video_info_changed && !redraw)) {
+  if (G_UNLIKELY ((self->video_info_changed && !redraw) || self->resend_info)) {
     info = &self->video_info;
     self->video_info_changed = FALSE;
+    self->resend_info = FALSE;
   }
   return gst_wl_window_render (self->window, wlbuffer, info);
 }
@@ -1083,18 +1084,21 @@ gst_wayland_sink_set_window_handle (GstVideoOverlay * overlay, guintptr handle)
 
   g_return_if_fail (self != NULL);
 
-  if (self->window != NULL) {
-    GST_WARNING_OBJECT (self, "changing window handle is not supported");
+  if (self->window_handle == handle)
     return;
-  }
+
+  self->window_handle = handle;
 
   g_mutex_lock (&self->render_lock);
 
+  if (self->window != NULL) {
+    GST_WARNING_OBJECT (self, "changing window handle is dangerous");
+    g_clear_object (&self->window);
+  }
+
   GST_DEBUG_OBJECT (self, "Setting window handle %" GST_PTR_FORMAT,
       (void *) handle);
 
-  g_clear_object (&self->window);
-
   if (handle) {
     if (G_LIKELY (gst_wayland_sink_find_display (self))) {
       /* we cannot use our own display with an external window handle */
@@ -1109,6 +1113,12 @@ gst_wayland_sink_set_window_handle (GstVideoOverlay * overlay, guintptr handle)
             &self->render_lock);
         gst_wl_window_set_rotate_method (self->window,
             self->current_rotate_method);
+
+        if (self->last_buffer) {
+          /* Resend video info to force resize video surface */
+          self->resend_info = TRUE;
+          self->redraw_pending = FALSE;
+        }
       }
     } else {
       GST_ERROR_OBJECT (self, "Failed to find display handle, "
diff --git a/ext/wayland/gstwaylandsink.h b/ext/wayland/gstwaylandsink.h
index 5bbb10a..7bf3a9b 100644
--- a/ext/wayland/gstwaylandsink.h
+++ b/ext/wayland/gstwaylandsink.h
@@ -52,6 +52,7 @@ struct _GstWaylandSink
   GstWlWindow *window;
   GstBufferPool *pool;
 
+  guintptr window_handle;
   gboolean video_info_changed;
   GstVideoInfo video_info;
   GstVideoInfoDmaDrm drm_info;
@@ -59,6 +60,7 @@ struct _GstWaylandSink
   GstCaps *caps;
 
   gchar *display_name;
+  gboolean resend_info;
 
   GMutex render_lock;
   GstBuffer *last_buffer;
-- 
2.43.0

