From 9fb5e5e7cefc7c8b32d24308e9b8b7f82330f630 Mon Sep 17 00:00:00 2001
From: Jeffy Chen <jeffy.chen@rock-chips.com>
Date: Thu, 29 Feb 2024 15:18:46 +0800
Subject: [PATCH 32/45] kmssink: Avoid choosing disconnected connector

The connectors might share CRTC, so CRTC's buffer doesn't mean connector
is used.

Signed-off-by: Jeffy Chen <jeffy.chen@rock-chips.com>

diff --git a/sys/kms/gstkmssink.c b/sys/kms/gstkmssink.c
index 4883c3e..9c62629 100644
--- a/sys/kms/gstkmssink.c
+++ b/sys/kms/gstkmssink.c
@@ -799,6 +799,9 @@ connector_is_used (int fd, drmModeRes * res, drmModeConnector * conn)
   gboolean result;
   drmModeCrtc *crtc;
 
+  if (conn->connection != DRM_MODE_CONNECTED)
+    return FALSE;
+
   result = FALSE;
   crtc = find_crtc_for_connector (fd, res, conn, NULL);
   if (crtc) {
