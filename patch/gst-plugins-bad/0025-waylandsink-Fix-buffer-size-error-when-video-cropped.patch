From 5882ec9815e0d9324d22d228fc83999b2592bb4f Mon Sep 17 00:00:00 2001
From: Build <build@local>
Date: Sun, 1 Mar 2026 13:50:24 +0800
Subject: [PATCH 25/45] waylandsink: Fix buffer size error when video cropped

---
 ext/wayland/gstwaylandsink.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/ext/wayland/gstwaylandsink.c b/ext/wayland/gstwaylandsink.c
index 0baa22e..fddef70 100644
--- a/ext/wayland/gstwaylandsink.c
+++ b/ext/wayland/gstwaylandsink.c
@@ -1056,6 +1056,10 @@ gst_wayland_sink_show_frame (GstVideoSink * vsink, GstBuffer * buffer)
       if (G_UNLIKELY (!wlbuffer)) {
         wbuf = gst_wl_linux_dmabuf_construct_wl_buffer (to_render,
             self->display, &self->drm_info);
+    /* prefer the padded width/height from vmeta */
+    self->video_info.width = vmeta->width;
+    self->video_info.height = vmeta->height;
+
 
         if (G_UNLIKELY (!wbuf)) {
           GST_WARNING_OBJECT (self, "failed to import DRM Dumb dmabuf");
