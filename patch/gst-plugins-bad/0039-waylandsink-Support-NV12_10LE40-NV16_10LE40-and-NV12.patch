+
   /* Use scaled size for centering */
   switch (priv->buffer_transform) {
     case WL_OUTPUT_TRANSFORM_NORMAL:
     case WL_OUTPUT_TRANSFORM_180:
     case WL_OUTPUT_TRANSFORM_FLIPPED:
     case WL_OUTPUT_TRANSFORM_FLIPPED_180:
+      src.x = video_x;
+      src.y = video_y;
       src.w = scaled_width;
       src.h = video_height;
       break;
@@ -565,6 +603,8 @@ gst_wl_window_resize_video_surface (GstWlWindow * self, gboolean commit)
     case WL_OUTPUT_TRANSFORM_270:
     case WL_OUTPUT_TRANSFORM_FLIPPED_90:
     case WL_OUTPUT_TRANSFORM_FLIPPED_270:
+      src.x = video_y;
+      src.y = video_x;
       src.w = video_height;
       src.h = scaled_width;
       swapped = TRUE;
@@ -714,6 +754,8 @@ gst_wl_window_commit_buffer (GstWlWindow * self, GstWlBuffer * buffer)
     wl_subsurface_set_sync (priv->video_subsurface);
     gst_wl_window_resize_video_surface (self, FALSE);
     gst_wl_window_set_opaque (self, info);
+  } else if (priv->crop_dirty) {
+    gst_wl_window_resize_video_surface (self, FALSE);
   }
 
   if (G_LIKELY (buffer)) {
